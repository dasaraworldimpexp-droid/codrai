NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/codrai
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codrai
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=postmessage
GOOGLE_AUTHORIZED_ORIGIN=http://localhost:5173
GOOGLE_AUTHORIZED_REDIRECT=http://localhost:5173/auth/google/callback
# Legacy alias supported for existing deployments. Prefer GOOGLE_AUTHORIZED_REDIRECT.
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback
PROVIDER_ENCRYPTION_KEY=replace_with_a_long_random_provider_key
PROVIDER_HTTP_TIMEOUT_MS=30000
OPENAI_SDK_MAX_RETRIES=1
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_DEFAULT_VOICE_ID=your_default_voice_id
FAL_API_KEY=your_fal_api_key
STABILITY_API_KEY=your_stability_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
TOGETHER_API_KEY=your_together_api_key
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
RUNWAY_API_KEY=your_runway_api_key
REPLICATE_API_TOKEN=your_replicate_api_token
DEFAULT_TEXT_MODEL=gpt-4o-mini
DEFAULT_CODING_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_IMAGE_MODEL=gpt-image-1
FILE_STORAGE_DIR=./storage/uploads
ENABLE_TERMINAL_TOOL=false
ENABLE_FILE_WRITE_TOOL=false
TOOL_WORKSPACE_ROOT=./tool-workspace
PLAYWRIGHT_HEADLESS=true
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PRICE_PREMIUM=your_stripe_price_id
PUBLIC_APP_URL=http://localhost:5173
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
