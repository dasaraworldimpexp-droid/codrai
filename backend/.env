NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codrai
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
DEFAULT_TEXT_MODEL=gpt-4o-mini
DEFAULT_CODING_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_IMAGE_MODEL=gpt-image-1
FILE_STORAGE_DIR=./storage/uploads
ENABLE_TERMINAL_TOOL=false
ENABLE_FILE_WRITE_TOOL=false
TOOL_WORKSPACE_ROOT=./tool-workspace
PLAYWRIGHT_HEADLESS=true
PUBLIC_APP_URL=http://localhost:5173
